# ─────────────────────────────────────────────────────────
# AndeXCertify — Environment Variables
# Copy this file to .env and fill in all values.
# VITE_* vars are bundled into the frontend build.
# All other vars are server-side only (never sent to the browser).
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
APP_URL="https://certify.tudominio.cl"
PORT=3000

# ── Multi-tenant domains ─────────────────────────────────
# Base domain under which tenant subdomains are served:
#   BASE_DOMAIN=certify.tudominio.cl  →  laboralcap.certify.tudominio.cl
# Requires a wildcard DNS record:  *.certify.tudominio.cl → <VPS IP>
BASE_DOMAIN="certify.tudominio.cl"

# Email for Let's Encrypt / ACME account (certificate expiry notices).
ACME_EMAIL="admin@tudominio.cl"

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed browser origins (exact match, no trailing slash).
# Requests from unlisted origins will be rejected with a CORS error.
ALLOWED_ORIGINS=https://certify.tudominio.cl,https://app.tudominio.cl

# ── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL="postgresql://andex_user:password@localhost:5432/andexcertify"

# ── JWT Auth (self-hosted) ────────────────────────────────
# Generate strong random secrets for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change-me-in-production-min-64-chars"
JWT_REFRESH_SECRET="change-me-in-production-min-64-chars"

# ── Superadmin bootstrap ──────────────────────────────────
# UUID del primer usuario superadmin (debe existir en la tabla users).
# Pasos:
#   1. Registra el usuario a través de la app o via /api/auth/register
#   2. Copia su UUID de la tabla users y ponlo aquí.
#   3. Despliega / reinicia el servidor — el rol se asigna automáticamente.
SUPERADMIN_USER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
SUPERADMIN_EMAIL="superadmin@tudominio.cl"

# ── Email (SMTP) ──────────────────────────────────────────
# Used to send invitations and password-reset emails.
# If empty, emails are logged to the console (the invite link still works).
# Port 465 → SMTP_SECURE=true · Port 587 (STARTTLS) → SMTP_SECURE=false
SMTP_HOST="smtp.tuproveedor.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="usuario@tudominio.cl"
SMTP_PASS="tu-contraseña-smtp"
SMTP_FROM="AndeXCertify <no-reply@tudominio.cl>"

# ── Object Storage ────────────────────────────────────────
# STORAGE_DRIVER: dónde se guardan logos/firmas/plantillas.
#   local → carpeta ./dev-storage (desarrollo)
#   s3    → S3-compatible (producción) — requiere las variables S3_* de abajo
#   vacío → local si DEV_MODE=true, si no s3
STORAGE_DRIVER="s3"

# ── S3-Compatible Object Storage (solo si STORAGE_DRIVER=s3) ──
# Works with Hetzner Object Storage, Backblaze B2, AWS S3, MinIO, etc.
S3_ENDPOINT="https://fsn1.your-objectstorage.com"
S3_REGION="eu-central"
S3_BUCKET="andexcertify"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"

# ── Gemini AI ─────────────────────────────────────────────
GEMINI_API_KEY="AIza..."

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Settings Rules
    match /settings/{userId} {
      allow get: if true; // Public for validation (logo, name, etc)
      allow list, write: if isOwner(userId);
      
      match /representatives/{repId} {
        allow get: if true; // Public for validation/download
        allow list, write: if isOwner(userId);
      }
    }

    // Courses Rules
    match /courses/{courseId} {
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow get: if true; // Public for validation
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // Enrollments Rules
    match /enrollments/{enrollmentId} {
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow get: if true; // Public for validation
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // Templates Rules
    match /templates/{templateId} {
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow get: if true; // Public for validation/download
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }
  }
}
